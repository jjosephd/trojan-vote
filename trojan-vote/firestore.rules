rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    // Check if the user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the user matches the provided UID
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Check if the user has the 'admin' custom claim
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Check if a specific election is currently open
    function isElectionOpen(electionId) {
      return get(/databases/$(database)/documents/elections/$(electionId)).data.status == 'open';
    }

    // --- Collection Rules ---

    // Users: Users can read profiles if signed in. 
    // All writes are handled via Admin SDK (Cloud Functions/Auth triggers).
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Elections: All signed-in users can read election metadata.
    // Writes are restricted to Admins (handled by Cloud Functions).
    match /elections/{electionId} {
      allow read: if isSignedIn();
      allow write: if false;

      // Candidates: Sub-collection of elections. Read-only for users.
      match /candidates/{candidateId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // Votes: Immutable records. 
    // Users can read their own votes. Admins can read all votes.
    // Creation and deletion are forbidden (handled by submitVote Function).
    match /votes/{voteId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false;
    }

    // Audit Logs: System-wide logs accessible only by Admins.
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
